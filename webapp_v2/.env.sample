# Webapp V2 Environment Variables
#
# This file is OPTIONAL. All variables below have working defaults in
# vite.config.js — `npm run dev` and `npm run dev:full` work out of the box
# without a .env file. Only create one if you need to override a default.

# VITE_API_URL — runtime backend base URL.
# Defaults to "/api" (relative to the current domain), so the app reaches the
# gateway through whatever origin serves index.html.
# VITE_API_URL=/api
# VITE_API_URL=https://api.custom-domain.com

# VITE_GATEWAY_URL — dev-only. Where Vite proxies /api during `npm run dev`.
# Defaults to http://localhost:8009 (the local gateway).
# VITE_GATEWAY_URL=http://localhost:8009

# VITE_CLJS_URL — dev-only. Where Vite proxies /js, /css, /images, /data
# and /icons during `npm run dev` (i.e. the shadow-cljs dev server).
# Defaults to http://localhost:8280.
# Start the ClojureScript dev server with:
#   cd ../webapp && npm run dev:hoop-ui
# Or run both together from this folder:
#   npm run dev:full
# VITE_CLJS_URL=http://localhost:8280
