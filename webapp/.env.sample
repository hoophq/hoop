################################
# hoop specific configurations #
################################
#
# This file is OPTIONAL. All variables below are read via `#shadow/env`
# in shadow-cljs.edn with fallback defaults, so `npm run dev:hoop-ui`
# works without a .env. Only set these if you want to override a default
# (e.g. point Sentry at your own DSN during dev).

# API_URL - OPTIONAL: Custom API endpoint
#
# If not set, the webapp will automatically determine the API URL:
# - uses the current domain + /api
#
# export API_URL=https://api.custom-domain.com

